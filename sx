ToggleBtn.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        toggleDrag = true
        toggleStart = i.Position
        togglePos = ToggleBtn.Position
    end
end)
ToggleBtn.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        toggleDrag = false
    end
end)
UserInputService.InputChanged:Connect(function(i)
    if toggleDrag and (i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseMovement) then
        local d = i.Position - toggleStart
        ToggleBtn.Position = UDim2.new(togglePos.X.Scale, togglePos.X.Offset + d.X, togglePos.Y.Scale, togglePos.Y.Offset + d.Y)
    end
end)

