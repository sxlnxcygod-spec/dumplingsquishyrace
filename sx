SubmitBtn.MouseButton1Click:Connect(function()
    local key = KeyBox.Text:gsub("%s+", "")
    if #key == 0 then
        StatusLbl.TextColor3 = THEME.RED
        StatusLbl.Text = "Please enter a key."
        return
    end
    SubmitBtn.Text = "CHECKING..."
    SubmitBtn.BackgroundColor3 = THEME.BORDER
    task.wait(0.3)
    if key == VALID_KEY then
        StatusLbl.TextColor3 = THEME.SUCCESS
        StatusLbl.Text = "Key accepted! Welcome to Nexus."
        task.wait(0.5)
        KeyGui:Destroy()
        ToggleBtn.Visible = true
        Win.Visible = true
    else
        SubmitBtn.Text = "VERIFY"
        SubmitBtn.BackgroundColor3 = THEME.RED
        StatusLbl.TextColor3 = THEME.RED
        StatusLbl.Text = "Invalid key. Join Discord to get one."
    end
end)

