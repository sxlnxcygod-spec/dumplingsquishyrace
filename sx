local function setToggle(hit, lbl, pill, knob, state, text, on)
    state = on
    lbl.Text = text .. ": " .. (on and "ON" or "OFF")
    tw(pill, { BackgroundColor3 = on and THEME.RED or THEME.BORDER })
    tw(knob, { Position = on and UDim2.new(1, -13, 0.5, -5) or UDim2.new(0, 3, 0.5, -5) })
    return state
end

